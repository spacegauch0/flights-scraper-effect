{
  "name": "flights-scraper-effect",
  "version": "1.0.0",
  "description": "Google Flights Scraper using TypeScript Effect and Puppeteer",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "start": "bun run src/cli.ts",
    "cli": "bun run src/cli.ts",
    "tui": "bun run src/cli.ts --tui",
    "tui:mock": "FLIGHTS_TUI_MOCK=1 bun run src/cli.ts --tui",
    "production": "bun run src/cli.ts --production",
    "typecheck": "tsc --noEmit",
    "test": "bun test ./test/",
    "lint": "oxlint --tsconfig tsconfig.json src/ test/",
    "format": "oxfmt src/ test/",
    "format:check": "oxfmt --check src/ test/"
  },
  "dependencies": {
    "@effect/platform-node": "4.0.0-beta.93",
    "@opentui/core": "^0.4.2",
    "@opentui/react": "0.4.2",
    "cheerio": "^1.2.0",
    "effect": "4.0.0-beta.93",
    "protobufjs": "^8.6.5",
    "puppeteer": "^25.3.0",
    "react": "19.2.7",
    "scheduler": "0.27.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@types/react": "19.2.17",
    "oxfmt": "0.56.0",
    "oxlint": "1.71.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
