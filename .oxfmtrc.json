{
	"$schema": "./node_modules/oxfmt/configuration_schema.json",
	"printWidth": 180,
	"useTabs": false,
	"tabWidth": 2,
	"semi": false,
	"singleQuote": false,
	"jsxSingleQuote": false,
	"quoteProps": "as-needed",
	"trailingComma": "all",
	"bracketSpacing": true,
	"bracketSameLine": false,
	"arrowParens": "always",
	"endOfLine": "lf",
	"insertFinalNewline": true,
	"objectWrap": "preserve",
	"sortImports": false,
	"sortPackageJson": false,
	"ignorePatterns": ["node_modules/**", "dist/**", "coverage/**"]
}
